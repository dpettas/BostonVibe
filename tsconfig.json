{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "rootDir": "src",
    "outDir": "js",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "removeComments": false
  },
  "include": ["src/**/*.ts"]
}
